# Configuration de déploiement cPanel — copier vers .deploy.env et remplir

# Connexion SSH (rsync)
SSH_HOST=votre-domaine.com
SSH_USER=votre_utilisateur_cpanel
SSH_PORT=22
SSH_TARGET_DIR=/home/votre_utilisateur/apps/backstage

# Variables d'environnement production
NEXT_PUBLIC_API_URL=https://opencode.ai/zen/go/v1
IA_API_KEY=votre_api_key
GOOGLE_CLIENT_ID=votre_client_id
GOOGLE_CLIENT_SECRET=votre_client_secret
GOOGLE_REDIRECT_URI=https://votre-domaine.com/api/auth/google/callback
AUTH_SECRET=votre_secret_64_hex
OPENWEATHERMAP_API_KEY=votre_key
BRAVE_SEARCH_API_KEY=votre_key
